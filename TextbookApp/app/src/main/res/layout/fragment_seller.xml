<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dim">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Form card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="List a Textbook"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/editTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Book title"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="@drawable/input_bg"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                android:inputType="textCapWords" />

            <EditText
                android:id="@+id/editSeller"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Your name"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="@drawable/input_bg"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/editPrice"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Price (R)"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="@drawable/input_bg"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                android:inputType="numberDecimal" />

            <!-- Banking section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/banking_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏦  Banking Details"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/editBankName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Bank name (e.g. FNB)"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:background="@drawable/input_bg"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:inputType="textCapWords" />

                <EditText
                    android:id="@+id/editAccNumber"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Account number"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:background="@drawable/input_bg"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:inputType="number" />

                <EditText
                    android:id="@+id/editAccType"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Account type (Cheque / Savings)"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:background="@drawable/input_bg"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:inputType="textCapWords" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Confirm Listing"
                android:backgroundTint="@color/navy"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                app:cornerRadius="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>
        </LinearLayout>

        <!-- Listings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR LISTINGS"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/listingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
