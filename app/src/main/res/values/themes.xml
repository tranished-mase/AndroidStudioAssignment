<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TextbookAPP" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/navy</item>
        <item name="colorPrimaryVariant">@color/navy_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="colorSecondaryVariant">@color/gold</item>
        <item name="colorOnSecondary">@color/navy</item>
        <item name="android:statusBarColor">@color/navy</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="InputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>
</resources>
