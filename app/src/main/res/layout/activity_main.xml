<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:elevation="4dp"
            app:queryHint="Search by title or seller..."
            android:layout_marginBottom="20dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="List a New Textbook"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/editTitle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Book Title"
                    android:paddingLeft="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/editSeller"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Seller Name"
                    android:paddingLeft="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/editPrice"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Price (e.g. 150.00)"
                    android:inputType="numberDecimal"
                    android:paddingLeft="10dp"
                    android:drawableStart="@android:drawable/ic_menu_send"
                    android:drawablePadding="8dp"
                    android:background="@android:drawable/editbox_background"
                    android:layout_marginBottom="10dp"/>


                <EditText
                    android:id="@+id/editBankName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Bank Name (e.g., Capitec)"
                    android:paddingLeft="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/editAccNumber"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Account Number"
                    android:inputType="number"
                    android:paddingLeft="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:layout_marginBottom="10dp"/>


                <EditText
                    android:id="@+id/editAccType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Account Type (e.g., Savings)"
                    android:paddingLeft="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:layout_marginBottom="20dp"/>
                <Button
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Confirm Listing"
                    android:backgroundTint="@color/primary_green"
                    android:textColor="@android:color/white"
                    app:cornerRadius="8dp"/>
                <TextView
                    android:id="@+id/textInventory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Available Books: None"
                    android:padding="10dp"
                    android:textColor="@color/black" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>